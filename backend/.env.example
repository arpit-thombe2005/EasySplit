# EasySplit Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────
# Neon PostgreSQL connection string (from https://console.neon.tech/)
DATABASE_URL=

# ── JWT Auth ──────────────────────────────────────────────────────
# Any random string of 32+ characters used to sign security tokens
JWT_SECRET=
JWT_EXPIRES_IN=30d

# ── Email (Nodemailer - Gmail App Password or any SMTP) ───────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=EasySplit <noreply@easysplit.app>

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
